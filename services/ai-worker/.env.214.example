APP_ENV=production
AI_WORKER_IMAGE_TAG=latest
AI_WORKER_HOST_PORT=8090
AI_WORKER_CONSUME_REDIS=true
AI_WORKER_SCAN_STREAM=club:scan:tasks
AI_WORKER_REDIS_GROUP=club-ai-worker
AI_WORKER_REDIS_CONSUMER=ai-worker-214
AI_WORKER_RESULT_DIR_HOST=/data/club/ai-worker/results
AI_MODEL_VERSION=ai-worker-214

# If Go API and Redis run directly on server 214, keep host.docker.internal.
# If they run on another server or another compose network, replace these values.
API_BASE_URL=http://host.docker.internal:8080
REDIS_ADDR=host.docker.internal:6379
REDIS_DB=0
REDIS_PASSWORD=

# Optional. Leave empty to use mock OCR. Set this to the PaddleOCR service URL for real OCR.
PADDLEOCR_SERVICE_URL=

# Optional third-party AI provider. Keep mock until the provider is ready.
AI_PROVIDER=mock
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=
AI_TIMEOUT_SECONDS=45
